    "solution": "<button id=\"menuBtn\" aria-label=\"Ouvrir le menu\" aria-expanded=\"false\">☰</button>\n<nav id=\"menu\" class=\"menu\"></nav>\n\nmenuBtn.addEventListener('click', () => {\n  menu.classList.toggle('is-open');\n  menuBtn.setAttribute('aria-expanded', menu.classList.contains('is-open'));\n});",
    "checks": [
      {
        "label": "Le bouton a un nom accessible.",
        "contains": "aria-label"
      },
      {
        "label": "aria-expanded est gere.",
        "contains": "aria-expanded"
      },
      {
        "label": "L'etat CSS passe par classList.",
        "contains": "classList.toggle",
        "absent": "style.display"
      }
    ],
    "tests": [
      {
        "type": "page",
        "mode": "html-js",
        "label": "Le bouton pilote un etat accessible apres clic.",
        "actions": [
          {
            "click": "#menuBtn"
          }
        ],
        "assertions": [
          {
            "selector": "#menuBtn",
            "attribute": "aria-label",
            "matches": ".+"
          },
          {
            "selector": "#menuBtn",
            "attribute": "aria-expanded",
            "equals": "true"
          },
          {
            "selector": "#menu",
            "property": "className",
            "contains": "is-open"
          }
        ]
      }
    ],
    "explanation": "Le bouton doit etre nomme pour les lecteurs d'ecran et JavaScript doit piloter un etat CSS.",
    "references": [
      "accessibility",
      "dom",
      "components"
    ]
