    "id": "advanced-integration-js-state-fix-001",
    "domain": "integration",
    "topic": "components",
    "level": 5,
    "type": "code-fix",
    "question": "Corrige ce composant pour alterner l'etat ouvert.",
    "code": "<button id=\"toggle\" aria-expanded=\"false\">Menu</button>\n<nav id=\"menu\"></nav>\n\ntoggle.addEventListener('click', () => {\n  menu.classList.add('open');\n  toggle.setAttribute('aria-expanded', 'true');\n});",
    "solution": "<button id=\"toggle\" aria-expanded=\"false\">Menu</button>\n<nav id=\"menu\"></nav>\n\ntoggle.addEventListener('click', () => {\n  const open = menu.classList.toggle('open');\n  toggle.setAttribute('aria-expanded', String(open));\n});",
    "checks": [
      {
        "label": "classList.toggle est utilise.",
        "contains": "classList.toggle"
      },
      {
        "label": "aria-expanded suit l'etat.",
        "contains": "setAttribute('aria-expanded'"
      }
    ],
    "tests": [
      {
        "type": "page",
        "mode": "html-js",
        "label": "Deux clics ouvrent puis referment le menu.",
        "actions": [
          {
            "click": "#toggle"
          },
          {
            "click": "#toggle"
          }
        ],
        "assertions": [
          {
            "selector": "#toggle",
            "attribute": "aria-expanded",
            "equals": "false"
          },
          {
            "selector": "#menu",
            "property": "className",
            "equals": ""
          }
        ]
      }
    ],
    "explanation": "Un composant toggle doit pouvoir ouvrir et fermer, pas seulement ouvrir.",
    "references": [
      "components",
      "aria",
      "state"
    ]
