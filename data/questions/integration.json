  {
    "id": "integration-card-fix-001",
    "domain": "integration",
    "topic": "html-css",
    "level": 3,
    "type": "code-fix",
    "question": "Corrige ce composant carte : image accessible, lien valide, selecteur CSS de classe et unite sur le padding.",
    "code": "<article class=\"card\">\n  <img href=\"produit.jpg\">\n  <h2>Produit</h2>\n  <a src=\"produit.html\">Voir</a>\n</article>\n\n#card {\n  padding: 16;\n  background-color: #fff;\n}",
    "solution": "<article class=\"card\">\n  <img src=\"produit.jpg\" alt=\"Photo du produit\">\n  <h2>Produit</h2>\n  <a href=\"produit.html\">Voir</a>\n</article>\n\n.card {\n  padding: 16px;\n  background-color: #fff;\n}",
    "checks": [
      {
        "label": "L'image utilise src.",
        "contains": "src=\"produit.jpg\"",
        "absent": "img href"
      },
      {
        "label": "L'image possede alt.",
        "contains": "alt="
      },
      {
        "label": "Le lien utilise href.",
        "contains": "href=\"produit.html\"",
        "absent": "a src"
      },
      {
        "label": "Le CSS cible la classe .card.",
        "contains": ".card",
        "absent": "#card"
      },
      {
        "label": "Le padding possede une unite.",
        "contains": "padding: 16px;"
      }
    ],
    "tests": [
      {
        "type": "page",
        "mode": "html-css",
        "label": "La carte HTML/CSS est utilisable et stylee.",
        "assertions": [
          {
            "selector": ".card img",
            "attribute": "src",
            "contains": "produit.jpg"
          },
          {
            "selector": ".card img",
            "attribute": "alt",
            "matches": ".+"
          },
          {
            "selector": ".card a",
            "attribute": "href",
            "contains": "produit.html"
          },
          {
            "selector": ".card",
            "computed": "padding-top",
            "equals": "16px"
          }
        ]
      }
    ],
    "explanation": "Les attributs src/href doivent etre sur les bons elements et le CSS doit cibler .card.",
    "references": [
      "integration",
      "debug"
    ]
  },
