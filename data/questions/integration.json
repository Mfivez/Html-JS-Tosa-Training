  {
    "id": "integration-fetch-fix-001",
    "domain": "integration",
    "topic": "fetch",
    "level": 5,
    "type": "code-fix",
    "question": "Corrige cette fonction pour lire du JSON avec fetch.",
    "code": "async function loadUsers() {\n  const response = fetch('/users.json');\n  const users = response.json;\n  return users;\n}",
    "solution": "async function loadUsers() {\n  const response = await fetch('/users.json');\n  if (!response.ok) throw new Error('Erreur de chargement');\n  const users = await response.json();\n  return users;\n}",
    "checks": [
      {
        "label": "fetch est attendu avec await.",
        "contains": "await fetch"
      },
      {
        "label": "response.json() est appele.",
        "contains": "await response.json()"
      },
      {
        "label": "Le statut est verifie.",
        "contains": "response.ok"
      }
    ],
    "tests": [
      {
        "type": "console",
        "label": "La fonction attend fetch et retourne le JSON.",
        "before": "globalThis.fetch = async () => ({ ok: true, json: async () => [{ name: 'Ada' }] });",
        "after": "return loadUsers().then((users) => console.log(users[0].name));",
        "expectedLogs": [
          "Ada"
        ]
      }
    ],
    "explanation": "fetch et response.json() retournent des Promises, et le statut HTTP doit etre verifie.",
    "references": [
      "fetch",
      "async-await",
      "debug"
    ]
  },
