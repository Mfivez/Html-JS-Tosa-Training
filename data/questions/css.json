    "id": "archive-css-media-query-fix-001",
    "domain": "css",
    "topic": "responsive",
    "level": 4,
    "type": "code-fix",
    "question": "Corrige cette media query responsive.",
    "code": ".grid {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n}\n\n@media max-width: 768px {\n  .grid {\n    grid-template-column: 1fr;\n  }\n}",
    "solution": ".grid {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n}\n\n@media (max-width: 768px) {\n  .grid {\n    grid-template-columns: 1fr;\n  }\n}",
    "checks": [
      {
        "label": "La media query utilise des parentheses.",
        "contains": "@media (max-width: 768px)"
      },
      {
        "label": "grid-template-columns est au pluriel.",
        "contains": "grid-template-columns: 1fr;"
      },
      {
        "label": "La syntaxe incorrecte n'est plus presente.",
        "absent": "grid-template-column:"
      }
    ],
    "tests": [
      {
        "type": "css",
        "label": "La grille devient une seule colonne dans une petite zone.",
        "fixture": "<div class=\"grid\"><span>A</span><span>B</span></div>",
        "assertions": [
          {
            "selector": ".grid",
            "computed": "display",
            "equals": "grid"
          },
          {
            "selector": ".grid",
            "computed": "grid-template-columns",
            "matches": "^[0-9.]+px$"
          }
        ]
      }
    ],
    "explanation": "Les conditions media query s'ecrivent entre parentheses et la propriete Grid est au pluriel.",
    "references": [
      "responsive",
      "media-queries",
      "grid"
    ]
