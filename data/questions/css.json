    "solution": "#titre {\n  font-size: 2rem;\n  color: navy;\n}\n\n.panel {\n  background: #f5f5f5;\n  padding: 1rem;\n}",
    "checks": [
      {
        "label": "#titre cible correctement l'identifiant.",
        "contains": "#titre"
      },
      {
        "label": ".panel cible correctement la classe.",
        "contains": ".panel"
      },
      {
        "label": "Le faux selecteur #panel n'est plus la.",
        "absent": "#panel {"
      }
    ],
    "tests": [
      {
        "type": "css",
        "label": "Les styles s'appliquent aux bons elements.",
        "fixture": "<h1 id=\"titre\">Titre</h1><section class=\"panel\">Panel</section>",
        "assertions": [
          {
            "selector": "#titre",
            "computed": "font-size",
            "equals": "32px"
          },
          {
            "selector": ".panel",
            "computed": "background-color",
            "equals": "rgb(245, 245, 245)"
          }
        ]
      }
    ],
    "explanation": "# cible un identifiant, . cible une classe.",
    "references": [
      "selectors",
      "classes",
      "ids"
    ]
  },
