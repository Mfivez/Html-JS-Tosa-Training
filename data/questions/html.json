  {
    "id": "archive-html-navigation-fix-001",
    "domain": "html",
    "topic": "lists",
    "level": 3,
    "type": "code-fix",
    "question": "Corrige la navigation pour que chaque element de liste soit ferme.",
    "code": "<nav>\n  <ul>\n    <li><a href=\"index.html\">Accueil</a>\n    <li><a href=\"about.html\">A propos</a>\n    <li><a href=\"contact.html\">Contact</a>\n  </ul>\n</nav>",
    "solution": "<nav>\n  <ul>\n    <li><a href=\"index.html\">Accueil</a></li>\n    <li><a href=\"about.html\">A propos</a></li>\n    <li><a href=\"contact.html\">Contact</a></li>\n  </ul>\n</nav>",
    "checks": [
      {
        "label": "Accueil est dans un li ferme.",
        "contains": "<li><a href=\"index.html\">Accueil</a></li>"
      },
      {
        "label": "A propos est dans un li ferme.",
        "contains": "<li><a href=\"about.html\">A propos</a></li>"
      },
      {
        "label": "Contact est dans un li ferme.",
        "contains": "<li><a href=\"contact.html\">Contact</a></li>"
      }
    ],
    "tests": [
      {
        "type": "html",
        "label": "La navigation contient trois items de liste.",
        "assertions": [
          {
            "selector": "nav ul li",
            "count": true,
            "equals": "3"
          },
          {
            "selector": "nav li:first-child a",
            "attribute": "href",
            "contains": "index.html"
          },
          {
            "selector": "nav li:last-child a",
            "attribute": "href",
            "contains": "contact.html"
          }
        ]
      }
    ],
    "explanation": "Les navigateurs tolerent parfois les <li> non fermes, mais l'examen teste la rigueur de la syntaxe.",
    "references": [
      "lists",
      "navigation",
      "html"
    ]
  },
